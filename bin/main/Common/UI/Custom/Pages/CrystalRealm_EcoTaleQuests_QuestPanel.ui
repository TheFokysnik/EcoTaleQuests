      // === TOP (LEADERBOARD) TAB ========================================
      Group #TopContent {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Visible: false;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        // Header row
        Group { LayoutMode: Left; Anchor: (Height: 22); Padding: (Left: 4, Right: 4);
          Label #TopHPos  { Style: @SmGray; Anchor: (Width: 30); Text: "#"; }
          Label #TopHName { Style: @SmGray; FlexWeight: 1; Text: "Player"; }
          Label #TopHRank { Style: @SmGray; Anchor: (Width: 50); Text: "Rank"; }
          Label #TopHPts  { Style: @SmGray; Anchor: (Width: 70); Text: "Pts"; }
          Label #TopHDone { Style: @SmGray; Anchor: (Width: 60); Text: "Done"; }
