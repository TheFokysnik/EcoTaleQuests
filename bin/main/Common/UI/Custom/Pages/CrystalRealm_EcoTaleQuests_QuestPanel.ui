      // === ACTIVE TAB ====================================================
      Group #ActiveContent {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Visible: false;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Label #NoActiveMsg { Style: @Gray; Text: ""; Visible: false; Anchor: (Height: 24); }

        Group #A1 { Visible: false; LayoutMode: Top; Anchor: (Height: 56); Padding: (Left: 4, Right: 4, Top: 1, Bottom: 1);
