        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Label #NoWeeklyMsg { Style: @Gray; Text: ""; Visible: false; Anchor: (Height: 24); }

        Group #W1 { Visible: false; LayoutMode: Top; Anchor: (Height: 42); Padding: (Left: 4, Right: 4, Top: 1, Bottom: 1);
